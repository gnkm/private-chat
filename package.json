{
	"name": "private-chat",
	"private": true,
	"packageManager": "pnpm@9.15.4",
	"pnpm": {
		"overrides": {
			"qs": ">=6.15.2",
			"ws": ">=8.20.1"
		}
	},
	"scripts": {
		"lint": "biome check .",
		"format": "biome format --write .",
		"test": "pnpm -r test",
		"build": "pnpm --filter @private-chat/shared run build && pnpm --filter @private-chat/server run build && pnpm --filter @private-chat/web run build",
		"dev": "pnpm --parallel --filter @private-chat/server --filter @private-chat/web run dev",
		"start": "pnpm build && pnpm --filter @private-chat/server start"
	},
	"devDependencies": {
		"@biomejs/biome": "^1.9.4",
		"typescript": "catalog:",
		"vitest": "catalog:"
	}
}
